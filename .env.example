# Control plane
CONTROL_PLANE_PORT=8090
SHARED_PASSWORD=dev-password
COOKIE_SECRET=replace-me-with-a-random-local-secret
ADMIN_USERS=
USE_FAKE_PROVIDER=false

# Optional HassleOff fail-safe service. Leave HASSLEOFF_URL and the shared token
# empty for the default NeurOn-only Compose experience. The controller token
# must be at least 16 characters when enabled.
HASSLEOFF_URL=
HASSLEOFF_CONTROLLER_TOKEN=
HASSLEOFF_CONTROLLER_ID=neuron-local
HASSLEOFF_REQUEST_TIMEOUT_SECONDS=5
HASSLEOFF_FAILSAFE_TEST_TARGET_ID=hassleoff-failsafe-test
HASSLEOFF_HOST_PORT=8091
HASSLEOFF_IMAGE=ghcr.io/cvalusek/hassleoff:latest
HASSLEOFF_SQLITE_PATH=/app/data/hassleoff.db
HASSLEOFF_TARGETS_FILE_HOST=./hassleoff/examples/targets.local.json
# Refer to this variable by name from a runpod-stop registration's apiKeyEnv.
HASSLEOFF_RUNPOD_API_KEY=

# Optional GitHub sign-in. The callback URL is:
# http://localhost:8090/auth/github/callback
GITHUB_AUTH_ENABLED=false
GITHUB_AUTH_CLIENT_ID=
GITHUB_AUTH_CLIENT_SECRET=
GITHUB_AUTH_ALLOWED_USERS=
GITHUB_AUTH_ALLOWED_ORGS=

# Capacity target config
CAPACITY_TARGETS_FILE=
CAPACITY_TARGETS_JSON=
CAPACITY_TARGET_KEYS=LOCAL

# Reconciler/UI polling
RECONCILER_INTERVAL_SECONDS=15
RESERVATION_STATUS_POLL_SECONDS=5
ADMIN_STATUS_POLL_SECONDS=10
HEALTH_CHECK_TIMEOUT_SECONDS=5
HEALTH_CHECK_INTERVAL_SECONDS=15

# LiteLLM integration
LITELLM_API_BASE_URL=
LITELLM_API_KEY=
LITELLM_TRAFFIC_POLL_SECONDS=60
LITELLM_TRAFFIC_LOOKBACK_SECONDS=300

# AWS provider, for non-local targets
AWS_REGION=us-east-1
RUNPOD_API_KEY=

# Env-expanded target config, alternative to CAPACITY_TARGETS_JSON/CAPACITY_TARGETS_FILE
# CAPACITY_TARGET_KEYS=MULTIPLE_MOE_96GB
# CAPACITY_TARGET_GPU_POOL_ID=gpu-pool
# CAPACITY_TARGET_GPU_POOL_DISPLAY_NAME=GPU Pool
# CAPACITY_TARGET_GPU_POOL_PROVIDER=aws-ecs
# CAPACITY_TARGET_GPU_POOL_HEALTH_CHECK_URL=http://llm.internal:8080/health
# CAPACITY_TARGET_GPU_POOL_AWS_CLUSTER=llm-cluster
# CAPACITY_TARGET_GPU_POOL_AWS_SERVICE=llama-cpp-gpu-pool
# CAPACITY_TARGET_GPU_POOL_AWS_ASG_NAME=llm-gpu-pool-asg
# CAPACITY_TARGET_GPU_POOL_MODEL_KEYS=QWEN,GEMMA
# CAPACITY_TARGET_GPU_POOL_MODEL_QWEN_ID=qwen
# CAPACITY_TARGET_GPU_POOL_MODEL_QWEN_DISPLAY_NAME=Qwen
# CAPACITY_TARGET_GPU_POOL_MODEL_QWEN_FAMILY=Qwen
# CAPACITY_TARGET_GPU_POOL_MODEL_QWEN_ALIASES=qwen-latest
# CAPACITY_TARGET_GPU_POOL_MODEL_QWEN_BACKEND_MODEL_IDS=qwen,qwen-latest
# CAPACITY_TARGET_GPU_POOL_MODEL_QWEN_CONTEXT_LABEL=256k

# Docker container target
CAPACITY_TARGET_LOCAL_ID=local
CAPACITY_TARGET_LOCAL_DISPLAY_NAME=PreFer Local
CAPACITY_TARGET_LOCAL_PROVIDER=docker
CAPACITY_TARGET_LOCAL_HEALTH_CHECK_URL=http://host.docker.internal:8080/health
CAPACITY_TARGET_LOCAL_DOCKER_CONTAINER_NAME=prefer
CAPACITY_TARGET_LOCAL_DOCKER_IMAGE=ghcr.io/cvalusek/prefer:latest
CAPACITY_TARGET_LOCAL_DOCKER_PORTS=8080:8080
CAPACITY_TARGET_LOCAL_DOCKER_VOLUMES=prefer-model-cache:/models
CAPACITY_TARGET_LOCAL_DOCKER_GPUS=all
CAPACITY_TARGET_LOCAL_DOCKER_ENV_KEYS=LLAMA_ARG_MODELS_MAX
CAPACITY_TARGET_LOCAL_DOCKER_ENV_LLAMA_ARG_MODELS_MAX=1
CAPACITY_TARGET_LOCAL_TRAFFIC_MODEL_PREFIXES=prefer/
# Enable only after HassleOff is healthy, armed, and its synthetic fail-safe
# test has succeeded for the exact registration file in use.
CAPACITY_TARGET_LOCAL_HASSLEOFF_PROTECTED=false
CAPACITY_TARGET_LOCAL_HASSLEOFF_LEASE_DURATION_SECONDS=120
CAPACITY_TARGET_LOCAL_HASSLEOFF_SHUTDOWN_ON_STALE_TRIP_TEST=false
CAPACITY_TARGET_LOCAL_HASSLEOFF_TRIP_TEST_MAX_AGE_SECONDS=86400

# App-only development/testing
# USE_FAKE_PROVIDER=true
# CAPACITY_TARGETS_FILE=examples/capacity-targets.local-fake.json
# CAPACITY_TARGET_KEYS=

# RunPod target example
# CAPACITY_TARGET_KEYS=RUNPOD
# CAPACITY_TARGET_RUNPOD_ID=prefer-runpod
# CAPACITY_TARGET_RUNPOD_DISPLAY_NAME=PreFer RunPod
# CAPACITY_TARGET_RUNPOD_PROVIDER=runpod
# CAPACITY_TARGET_RUNPOD_RUNPOD_POD_ID=your-runpod-pod-id
# CAPACITY_TARGET_RUNPOD_RUNPOD_API_KEY_ENV=RUNPOD_API_KEY
# CAPACITY_TARGET_RUNPOD_RUNPOD_RUNTIME_PORT=8080
# CAPACITY_TARGET_RUNPOD_RUNTIME_API_BASE_URL=https://your-pod-host-or-proxy.example.com/v1
# CAPACITY_TARGET_RUNPOD_TRAFFIC_MODEL_PREFIXES=prefer/
